@using Microondas.Domain.Localization
@inject ILocalizationService LocalizationService

<div class="language-selector">
    <label>@LocalizationService.GetString("language.select"): </label>
    <select @onchange="OnLanguageChanged" value="@LocalizationService.CurrentLanguage">
        <option value="en">@LocalizationService.GetString("language.english")</option>
        <option value="pt-BR">@LocalizationService.GetString("language.portuguese_br")</option>
    </select>
</div>

@code {
    private void OnLanguageChanged(ChangeEventArgs e)
    {
        if (e.Value is string language)
        {
            LocalizationService.SetLanguage(language);
            StateHasChanged();
        }
    }
}

<style>
    .language-selector {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        background: #f5f5f5;
        border-radius: 5px;
        margin-bottom: 15px;
    }

    .language-selector label {
        font-weight: bold;
        margin: 0;
    }

    .language-selector select {
        padding: 5px 10px;
        border: 1px solid #ddd;
        border-radius: 4px;
        cursor: pointer;
        background: white;
    }

    .language-selector select:hover {
        border-color: #999;
    }
</style>

